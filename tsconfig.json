{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "paths": {
            "@alentapp/shared": [
                "../shared/index.ts"
            ]
        }
    },
    "exclude": [
        "node_modules",
        "packages/*/dist",
        "packages/*/coverage",
        "packages/*/e2e",
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.integration.test.ts",
        "**/*.e2e.test.ts",
        "**/*.spec.ts"
    ]
}