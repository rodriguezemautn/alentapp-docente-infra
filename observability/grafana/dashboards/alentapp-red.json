{
  "title": "Alentapp RED \u2014 API",
  "uid": "alentapp-red-dashboard",
  "description": "M\u00e9tricas RED (Rate, Errors, Duration) de la API \u2014 OpenTelemetry",
  "tags": [
    "alentapp",
    "api",
    "otel",
    "red"
  ],
  "timezone": "America/Argentina/Buenos_Aires",
  "panels": [
    {
      "title": "Requests por segundo",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "Requests/s"
        }
      ],
      "description": "Cantidad de requests HTTP por segundo"
    },
    {
      "title": "Tasa de error",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(http_requests_errors_total[5m]) / rate(http_requests_total[5m]) * 100",
          "legendFormat": "Error %"
        }
      ],
      "description": "Porcentaje de errores sobre el total de requests"
    },
    {
      "title": "Requests activos concurrentes",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "expr": "http_requests_active",
          "legendFormat": "Activos"
        }
      ],
      "description": "Cantidad de requests siendo procesados actualmente"
    },
    {
      "title": "Latencia p95",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_bucket[5m]))",
          "legendFormat": "p95"
        }
      ],
      "description": "Percentil 95 de latencia \u2014 el 95% de los requests responden en este tiempo"
    },
    {
      "title": "Latencia p99",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "description": "Percentil 99 de latencia \u2014 si sube de 2000ms hay lentitud"
    },
    {
      "title": "Memoria del proceso",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "process_memory_usage / 1024 / 1024",
          "legendFormat": "Heap (MB)"
        }
      ],
      "description": "Memoria heap utilizada por el proceso Node.js en MB"
    },
    {
      "title": "HTTP Status Codes (fastify-metrics)",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{status=~\"2..\"}[5m])",
          "legendFormat": "2xx"
        },
        {
          "expr": "rate(http_requests_total{status=~\"4..\"}[5m])",
          "legendFormat": "4xx"
        },
        {
          "expr": "rate(http_requests_total{status=~\"5..\"}[5m])",
          "legendFormat": "5xx"
        }
      ],
      "description": "Distribuci\u00f3n de c\u00f3digos HTTP (disponible solo en dev con fastify-metrics)"
    }
  ],
  "schemaVersion": 38,
  "version": 1,
  "editable": true
}