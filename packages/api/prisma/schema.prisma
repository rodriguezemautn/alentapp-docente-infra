// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
    provider = "prisma-client-js"
    output   = "../src/generated/client"
}

datasource db {
    provider = "postgresql"
}

enum MemberCategory {
    Pleno
    Cadete
    Honorario
}

enum MemberStatus {
    Activo
    Moroso
    Suspendido
}

enum SportCategory {
    Senior
    Lifetime
    Cadet
}

model Member {
    id         String         @id @default(uuid())
    dni        String         @unique
    name       String
    email      String         @unique
    birthdate  DateTime?      @db.Date
    category   MemberCategory
    status     MemberStatus   @default(Activo)
    sportCategory SportCategory?
    created_at DateTime       @default(now())
    payments            Payment[]
    medicalCertificates  MedicalCertificate[]
    lockers             Locker[]
    equipmentLoans      EquipmentLoan[]
    lockerAssignmentLogs LockerAssignmentLog[]

    @@map("members") // Para que en la DB la tabla se llame 'members' en minúscula
}

model Sport {
    id          String       @id @default(uuid())
    name        String       @unique
    description String?
    maxCapacity Int
    created_at  DateTime     @default(now())
    disciplines Discipline[]

    @@map("sports")
}

model Discipline {
    id          String    @id @default(uuid())
    sportId     String
    sport       Sport     @relation(fields: [sportId], references: [id])
    name        String
    description String?
    startDate   DateTime  @db.Date
    endDate     DateTime  @db.Date
    schedule    String?
    professor   String?
    created_at  DateTime  @default(now())

    @@map("disciplines")
}

enum PaymentType {
    Cuota
    Mensualidad
    Inscripcion
    Otro
}

enum PaymentStatus {
    Completed
    Canceled
}

model Payment {
    id          String        @id @default(uuid())
    memberId    String
    member      Member        @relation(fields: [memberId], references: [id])
    amount      Decimal       @db.Decimal(10, 2)
    paymentDate DateTime      @default(now())
    paymentType PaymentType
    status      PaymentStatus @default(Completed)
    created_at  DateTime      @default(now())

    @@map("payments")
}

model MedicalCertificate {
    id              String    @id @default(uuid())
    memberId        String
    member          Member    @relation(fields: [memberId], references: [id])
    issueDate       DateTime  @default(now())
    expirationDate  DateTime?
    isActive        Boolean   @default(true)
    description     String?
    doctorName      String?
    created_at      DateTime  @default(now())

    @@map("medical_certificates")
}

enum LockerStatus {
    Available
    Occupied
    Maintenance
}

model Locker {
    id         String       @id @default(uuid())
    number     Int          @unique
    location   String?
    status     LockerStatus @default(Available)
    memberId   String?
    member     Member?      @relation(fields: [memberId], references: [id])
    created_at DateTime     @default(now())
    assignmentLogs LockerAssignmentLog[]

    @@map("lockers")
}

enum LockerEventType {
    Assignment
    Release
}

model LockerAssignmentLog {
    id         String           @id @default(uuid())
    lockerId   String
    locker     Locker           @relation(fields: [lockerId], references: [id])
    memberId   String
    member     Member           @relation(fields: [memberId], references: [id])
    eventType  LockerEventType
    assignedAt DateTime         @default(now())
    releasedAt DateTime?
    created_at DateTime         @default(now())

    @@map("locker_assignment_logs")
}

enum LoanStatus {
    Active
    Returned
    Lost
}

model EquipmentLoan {
    id            String     @id @default(uuid())
    memberId      String
    member        Member     @relation(fields: [memberId], references: [id])
    equipmentName String
    loanDate      DateTime   @default(now())
    returnDate    DateTime?
    status        LoanStatus @default(Active)
    notes         String?
    created_at    DateTime   @default(now())

    @@map("equipment_loans")
}
