{
  "name": "alentapp",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "e2e:fullstack": "playwright test --config playwright.fullstack.config.ts",
    "e2e:fullstack:ui": "npm run e2e:fullstack -- --ui",
    "e2e:fullstack:headed": "npm run e2e:fullstack -- --headed",
    "e2e:fullstack:ui:run": "npm run e2e:fullstack:up && npm run e2e:fullstack:ui",
    "e2e:fullstack:headed:run": "npm run e2e:fullstack:up && npm run e2e:fullstack:headed & npm run e2e:fullstack:down",
    "e2e:fullstack:up": "docker compose -f docker-compose.e2e.yml --project-name alentapp-e2e up -d --build",
    "e2e:fullstack:down": "docker compose -f docker-compose.e2e.yml --project-name alentapp-e2e down -v",
    "e2e:fullstack:run": "npm run e2e:fullstack:up && npm run e2e:fullstack & npm run e2e:fullstack:down",
    "prepare": "husky",
    "changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s -r 0",
    "changelog:next": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s",
    "version:bump": "standard-version --skip.changelog --skip.commit --skip.tag",
    "pr:create": "bash scripts/gh-automation.sh create-pr",
    "pr:merge": "bash scripts/gh-automation.sh merge-pr",
    "pr:status": "bash scripts/gh-automation.sh status"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "lint-staged": {
    "packages/web/src/**/*.{ts,tsx}": [
      "eslint --fix --config packages/web/eslint.config.js"
    ],
    "packages/api/src/**/*.ts": [
      "eslint --fix --config packages/api/eslint.config.js"
    ],
    "packages/shared/src/**/*.ts": [
      "prettier --write --ignore-unknown 2>/dev/null || true"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "conventional-changelog-cli": "^5.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
